#!/bin/sh

# Exit on error
set -e

# Get absolute path of script directory (portable method)
script_dir=$(cd "$(dirname "$0")" && pwd)
tt_metal_root=$(cd "$script_dir/../.." && pwd)

# Run from the generated graph directory so ./tensors paths resolve correctly.
cd "$script_dir"

# Set TT_METAL_RUNTIME_ROOT to this tt-metal checkout.
export TT_METAL_RUNTIME_ROOT="$tt_metal_root"

# Help CMake find the installed TT-NN/Metalium package exports before the
# generated build-tree configs in the build root.
ttnn_install_dir="${TTNN_INSTALL_DIR:-$tt_metal_root/build_Release}"
export CMAKE_PREFIX_PATH="$ttnn_install_dir/lib/cmake/tt-nn:$ttnn_install_dir/lib/cmake/tt-metalium:$ttnn_install_dir${CMAKE_PREFIX_PATH:+:$CMAKE_PREFIX_PATH}"

# Build
echo "==================== BUILDING TTNN STANDALONE ==================="
cmake -G Ninja -B build -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_COMPILER="${CXX:-clang++-20}"
cmake --build build -- ttnn-standalone
echo "================ FINISH BUILDING TTNN STANDALONE ================"

# Run
echo "==================== RUNNING TTNN STANDALONE ===================="
./build/ttnn-standalone
echo "================= FINISH RUNNING TTNN STANDALONE ================"
